# Database (required for app + seed scripts)
DATABASE_URL=

# Auth (min 16 chars)
AUTH_SECRET=

# Public app URL (production)
NEXT_PUBLIC_APP_URL=https://walrus-mu.vercel.app

# Walrus Memory / MemWal (Mainnet)
MEMORY_BACKEND=walrus
SUI_NETWORK=mainnet
MEMWAL_ACCOUNT_ID=
MEMWAL_DELEGATE_PRIVATE_KEY=
# Optional: owner wallet for one-time memwal:setup
# SUI_PRIVATE_KEY=
MEMWAL_SERVER_URL=https://relayer.memwal.ai

# LLM
GEMINI_API_KEY=

# Cron (cron-job.org → /api/cron/check-resolutions)
CRON_SECRET=
# CRON_JOB_API_KEY=  # for npm run cron:setup
# CRON_APP_URL=https://walrus-mu.vercel.app

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Optional
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
# WORLDCUP26_BASE_URL=
# ADMIN_SECRET=  # protects /api/admin/memwal-health in production
